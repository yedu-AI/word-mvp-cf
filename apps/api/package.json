{
  "name": "@word-mvp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml",
    "deploy": "wrangler deploy --config wrangler.toml",
    "typecheck": "tsc --noEmit",
    "password:hash": "node ./scripts/hash-password.mjs",
    "verify:auth": "node ./scripts/verify-auth.mjs",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate:local": "wrangler d1 migrations apply word_mvp --local",
    "drizzle:migrate:remote": "wrangler d1 migrations apply word_mvp --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.0",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.39.0"
  }
}
